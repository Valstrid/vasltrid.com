---
interface Props {
  lang?: 'en' | 'ar';
}

const { lang = 'en' } = Astro.props;
const isArabic = lang === 'ar';

const t = {
  en: {
    tagline: 'A Dubai-based Webflow design and development agency for startups and SaaS brands.',
    servicesTitle: 'Services',
    companyTitle: 'Company',
    process: 'Process',
    why: 'Why Valstrid',
    contact: 'Contact',
    copyright: 'Copyright © 2026 Valstrid™',
    location: 'Dubai, UAE',
    services: [
      'Webflow Design & Build',
      'UI/UX Design',
      'Brand Identity',
      'CMS & Integrations',
      'Ongoing Support'
    ]
  },
  ar: {
    tagline: 'وكالة تصميم وتطوير ويب فلو مقرها دبي للشركات الناشئة وعلامات SaaS.',
    servicesTitle: 'خدماتنا',
    companyTitle: 'الشركة',
    process: 'منهجيتنا',
    why: 'لماذا فالستريد',
    contact: 'تواصل معنا',
    copyright: 'حقوق النشر © 2026 فالستريد™',
    location: 'دبي، الإمارات العربية المتحدة',
    services: [
      'تصميم وبناء ويب فلو',
      'تصميم UI/UX',
      'الهوية البصرية',
      'CMS والتكاملات',
      'الدعم المستمر'
    ]
  }
}[lang];
---

