          {isArabic ? 'فالستريد' : 'Valstrid'}
        </a>
        <p>{t.tagline}</p>
      </div>
      <div class="footer-col">
        <h5>{t.servicesTitle}</h5>
        {t.services.map(service => (
          <a href="#services">{service}</a>
        ))}
      </div>
      <div class="footer-col">
        <h5>{t.companyTitle}</h5>
        <a href="#process">{t.process}</a>
        <a href="#why">{t.why}</a>
        <a href="mailto:hi@hisonrisa.com">{t.contact}</a>
